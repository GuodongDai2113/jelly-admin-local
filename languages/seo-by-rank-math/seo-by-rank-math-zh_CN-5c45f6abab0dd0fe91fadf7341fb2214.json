websites. ":["\u5bfc\u5165\u6216\u5bfc\u51fa\u60a8\u7684 Rank Math \u8bbe\u7f6e\u3002\u6b64\u9009\u9879\u53ef\u7528\u4e8e\u5728\u591a\u4e2a\u7f51\u7ad9\u4e4b\u95f4\u590d\u5236 Rank Math \u8bbe\u7f6e\u3002"],"Learn more about the Import\/Export options.":["\u4e86\u89e3\u6709\u5173\u5bfc\u5165\/\u5bfc\u51fa\u9009\u9879\u7684\u66f4\u591a\u4fe1\u606f\u3002"],"Import finished.":["\u5bfc\u5165\u5b8c\u6210\u3002"],"No posts found with SEO score.":["\u672a\u627e\u5230\u6709 SEO \u5206\u6570\u7684\u6587\u7ae0\u3002"],"Calculate SEO Scores":["\u8ba1\u7b97 SEO \u5206\u6570"],"Are you sure you want to import data from %s?":["\u60a8\u786e\u5b9a\u8981\u4ece %s \u5bfc\u5165\u6570\u636e\u5417\uff1f"],"Select data to import.":["\u9009\u62e9\u8981\u5bfc\u5165\u7684\u6570\u636e\u3002"],"Are you sure you want erase all traces of %s?":["\u60a8\u786e\u5b9a\u8981\u5220\u9664 %s \u7684\u6240\u6709\u75d5\u8ff9\u5417\uff1f"],"Clean":["\u6e05\u7406"],"Other Plugins":["\u5176\u4ed6\u63d2\u4ef6"],"If you were using another plugin to add important SEO information to your website before switching to Rank Math SEO, you can import the settings and data here. ":["\u672a\u68c0\u6d4b\u5230\u5305\u542b\u53ef\u5bfc\u5165\u6570\u636e\u7684\u63d2\u4ef6\u3002"],"No plugin detected with importable data.":["\u672a\u68c0\u6d4b\u5230\u5305\u542b\u53ef\u5bfc\u5165\u6570\u636e\u7684\u63d2\u4ef6\u3002"],"Create Backup":["\u521b\u5efa\u5907\u4efd"],"Settings Backup":["\u8bbe\u7f6e\u5907\u4efd"],"Take a backup of your plugin settings in case you wish to restore them in future. Use it as backup before making substantial changes to Rank Math settings. For taking a backup of the SEO data of your content, use the XML Export option.":["\u8bf7\u5907\u4efd\u60a8\u7684\u63d2\u4ef6\u8bbe\u7f6e\uff0c\u4ee5\u5907\u5c06\u6765\u9700\u8981\u6062\u590d\u65f6\u4f7f\u7528\u3002\u5728\u5bf9 Rank Math \u8bbe\u7f6e\u8fdb\u884c\u91cd\u5927\u66f4\u6539\u4e4b\u524d\uff0c\u8bf7\u5148\u8fdb\u884c\u5907\u4efd\u3002\u82e5\u8981\u5907\u4efd\u5185\u5bb9\u7684 SEO \u6570\u636e\uff0c\u8bf7\u4f7f\u7528\u201cXML \u5bfc\u51fa\u201d\u9009\u9879\u3002"],"Backup: %s":["\u5907\u4efd\uff1a%s"],"Are you sure you want to restore this backup? Your current configuration will be overwritten.":["\u60a8\u786e\u5b9a\u8981\u8fd8\u539f\u6b64\u5907\u4efd\u5417\uff1f\u60a8\u7684\u5f53\u524d\u914d\u7f6e\u5c06\u88ab\u8986\u76d6\u3002"],"Are you sure you want to delete this backup?":["\u60a8\u786e\u5b9a\u8981\u5220\u9664\u6b64\u5907\u4efd\u5417\uff1f"],"There is no backup.":["\u6ca1\u6709\u5907\u4efd\u3002"]}}}