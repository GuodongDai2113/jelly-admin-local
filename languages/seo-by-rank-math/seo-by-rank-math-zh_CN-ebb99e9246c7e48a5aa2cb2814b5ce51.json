{"translation-revision-date":"2026-07-21 15:46+0800","generator":"WP-CLI\/2.12.0","source":"assets\/admin\/js\/instantIndexingSettings.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"zh_CN","plural-forms":"nplurals=1; plural=0;"},"OK":["\u786e\u5b9a"],"Settings":["\u8bbe\u7f6e"],"History":["\u5386\u53f2\u8bb0\u5f55"],"Submit URLs":["\u63d0\u4ea4 URL"],"Send URLs directly to the IndexNow API.":["\u5c06 URL \u76f4\u63a5\u53d1\u9001\u5230 IndexNow API\u3002"],"The last 100 IndexNow API requests.":["\u6700\u540e 100 \u4e2a IndexNow API \u8bf7\u6c42\u3002"],"Insert URLs to send to the IndexNow API (one per line, up to 10,000):":["\u63d2\u5165\u8981\u53d1\u9001\u5230 IndexNow API \u7684 URL\uff08\u6bcf\u884c\u4e00\u4e2a\uff0c\u6700\u591a 10,000 \u4e2a\uff09\uff1a"],"URL slug placeholder\u0004hello-world":["hello-world"],"Clear History":["\u6e05\u9664\u5386\u53f2\u8bb0\u5f55"],"All":["\u5168\u90e8"],"Manual":["\u624b\u52a8"],"Auto":["\u81ea\u52a8"],"Time":["\u65f6\u95f4"],"URL":["URL"],"Response":["\u54cd\u5e94"],"Response Code Help":["\u54cd\u5e94\u4ee3\u7801\u5e2e\u52a9"],"Response Code":["\u54cd\u5e94\u4ee3\u7801"],"Response Message":["\u54cd\u5e94\u6d88\u606f"],"Reasons":["\u539f\u56e0"],"The URL was successfully submitted to the IndexNow API.":["URL\u5df2\u6210\u529f\u63d0\u4ea4\u5230IndexNow API\u3002"],"Accepted":["\u5df2\u63a5\u53d7"],"The URL was successfully submitted to the IndexNow API, but the API key will be checked later.":["URL\u5df2\u6210\u529f\u63d0\u4ea4\u5230IndexNow API\uff0c\u4f46\u7a0d\u540e\u5c06\u68c0\u67e5API\u5bc6\u94a5\u3002"],"Bad Request":["\u9519\u8bef\u8bf7\u6c42"],"The request was invalid.":["\u8bf7\u6c42\u65e0\u6548\u3002"],"Forbidden":["\u7981\u6b62\u8bbf\u95ee"],"The key was invalid (e.g. key not found, file found but key not in the file).":["\u5bc6\u94a5\u65e0\u6548\uff08\u4f8b\u5982\u5bc6\u94a5\uff09\u672a\u627e\u5230\uff0c\u5df2\u627e\u5230\u6587\u4ef6\uff0c\u4f46\u5bc6\u94a5\u4e0d\u5728\u6587\u4ef6\